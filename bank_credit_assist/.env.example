# API Keys（在此填入你的真实密钥）
MINERU_API_TOKEN=your_mineru_token_here
MINIMAX_API_KEY=your_minimax_key_here

# Minimax 模型（可选，默认 claude-3.5-sonnet）
# MINIMAX_MODEL=claude-3.5-sonnet-20240620

# 网络代理（本地开发如需要请取消注释）
# HTTP_PROXY=http://127.0.0.1:xxxx
# HTTPS_PROXY=http://127.0.0.1:xxxx
# NO_PROXY=localhost,127.0.0.1

# API 访问控制（生产环境必填，开发环境留空跳过认证）
# API_ACCESS_KEY=your_secret_api_key_here
